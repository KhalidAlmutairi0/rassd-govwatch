// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================
// USER — Platform users with role-based access
// ============================================
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  role            String    @default("developer") // governor | developer
  name            String?
  nameAr          String?
  isEmailVerified Boolean   @default(false)
  failedAttempts  Int       @default(0)
  lockedUntil     DateTime?
  slackWebhook    String?   // personal Slack webhook for alerts
  notifyEmail     Boolean   @default(true)
  notifySlack     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions          Session[]
  passwordResets    PasswordReset[]
  notifications     Notification[]
  scheduledReports  ScheduledReport[]
  directives        Directive[]
}

// ============================================
// SESSION — Auth session tokens
// ============================================
model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// PASSWORD RESET — Time-limited reset tokens
// ============================================
model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// NOTIFICATION — In-platform notification log
// ============================================
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("info") // incident | recovery | report | system | info
  read      Boolean  @default(false)
  metadata  String?  // JSON: extra context (siteId, runId, incidentId)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// ESCALATION TIMER — Persistent escalation state
// ============================================
model EscalationTimer {
  id            String    @id @default(cuid())
  incidentId    String    @unique
  currentLevel  Int       @default(1)  // 1=team_lead, 2=manager, 3=cto
  level1SentAt  DateTime?
  level2SentAt  DateTime?
  level3SentAt  DateTime?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  incident      Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

// ============================================
// SCHEDULED REPORT — Weekly report config
// ============================================
model ScheduledReport {
  id         String    @id @default(cuid())
  userId     String
  toEmail    String
  dayOfWeek  Int       @default(1)  // 0=Sun … 6=Sat
  hourOfDay  Int       @default(8)  // 0–23
  isActive   Boolean   @default(true)
  lastSentAt DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// SITE — A government website being monitored
// ============================================
model Site {
  id           String    @id @default(cuid())
  name         String
  nameAr       String?
  ministryName String?                         // Ministry this site belongs to
  baseUrl      String
  description  String?
  schedule     Int       @default(10)
  isPreset     Boolean   @default(false)
  isActive     Boolean   @default(true)
  status       String    @default("unknown")   // unknown | healthy | degraded | down
  lastRunAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  journeys    Journey[]
  runs        Run[]
  incidents   Incident[]
  scores      SiteScore[]
  directives  Directive[]
}

// ============================================
// JOURNEY — A test scenario for a site
// ============================================
model Journey {
  id          String   @id @default(cuid())
  siteId      String
  name        String
  type        String   @default("smoke")      // smoke | navigation | search | form | custom
  stepsJson   String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  runs        Run[]
  incidents   Incident[]
}

// ============================================
// RUN — A single execution of a journey
// ============================================
model Run {
  id                  String    @id @default(cuid())
  siteId              String
  journeyId           String
  status              String    @default("queued")    // queued | running | passed | failed | error | timeout
  durationMs          Int?
  totalSteps          Int       @default(0)
  passedSteps         Int       @default(0)
  failedSteps         Int       @default(0)
  summaryJson         String?
  errorJson           String?
  triggeredBy         String    @default("scheduler") // scheduler | manual | api
  aiPageUnderstanding String?
  aiTestPlan          String?
  aiSummary           String?
  startedAt           DateTime  @default(now())
  finishedAt          DateTime?

  site           Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  journey        Journey   @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  steps          RunStep[]
  artifacts      Artifact[]
  elementResults ElementTestResult[]
}

// ============================================
// RUN STEP — Individual step within a run
// ============================================
model RunStep {
  id             String  @id @default(cuid())
  runId          String
  stepIndex      Int
  action         String
  description    String
  selector       String?
  value          String?
  url            String?
  status         String  @default("pending")  // pending | running | passed | failed | skipped
  durationMs     Int?
  screenshotPath String?
  error          String?
  metadata       String?

  run            Run     @relation(fields: [runId], references: [id], onDelete: Cascade)
}

// ============================================
// ARTIFACT — Files generated during a run
// ============================================
model Artifact {
  id        String @id @default(cuid())
  runId     String
  type      String
  path      String
  sizeBytes Int?
  createdAt DateTime @default(now())

  run       Run    @relation(fields: [runId], references: [id], onDelete: Cascade)
}

// ============================================
// ELEMENT TEST RESULT
// ============================================
model ElementTestResult {
  id               String   @id @default(cuid())
  runId            String
  elementType      String
  elementText      String?
  elementTextAr    String?
  elementSelector  String
  parentSection    String?
  action           String
  status           String   @default("pending")
  responseTimeMs   Int?
  urlBefore        String?
  urlAfter         String?
  urlChanged       Boolean  @default(false)
  screenshotBefore String?
  screenshotAfter  String?
  consoleErrors    String?
  networkErrors    String?
  domChanges       String?
  error            String?
  cursorX          Int?
  cursorY          Int?
  createdAt        DateTime @default(now())

  run              Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
}

// ============================================
// INCIDENT — Grouped failures for a journey
// ============================================
model Incident {
  id          String    @id @default(cuid())
  siteId      String
  journeyId   String?
  title       String
  description String?
  status      String    @default("open")      // open | investigating | resolved
  severity    String    @default("medium")    // low | medium | high | critical
  occurrences Int       @default(1)
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  resolvedAt  DateTime?

  site             Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  journey          Journey?         @relation(fields: [journeyId], references: [id])
  escalationTimer  EscalationTimer?
}

// ============================================
// SITE SCORE — Historical score snapshots per site
// ============================================
model SiteScore {
  id           String   @id @default(cuid())
  siteId       String
  computedAt   DateTime @default(now())
  overallScore Int                          // 0–100
  grade        String                       // A | B | C | D | F
  uxScore      Int      @default(50)
  qaScore      Int      @default(50)
  accessScore  Int      @default(50)
  perfScore    Int      @default(50)
  execSummary  String?                      // AI-generated executive summary

  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

// ============================================
// DIRECTIVE — Governor-issued action directive
// ============================================
model Directive {
  id          String    @id @default(cuid())
  siteId      String
  issuedById  String                        // userId of the governor
  title       String
  body        String    @default("")
  status      String    @default("open")   // open | resolved | overdue
  dueDate     DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  issuedBy    User      @relation(fields: [issuedById], references: [id])
}
